{
  "name": "@yinshuo-thu/deepseek-cli",
  "version": "0.1.0",
  "description": "Native DeepSeek terminal coding agent — a Claude-Code-class TUI for the DeepSeek V4 model family.",
  "type": "module",
  "bin": {
    "deepseek": "./bin/deepseek.js",
    "ds": "./bin/deepseek.js"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test:smoke": "tsx scripts/smoke.ts"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-highlight": "^2.1.11",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^12.0.2",
    "marked-terminal": "^7.1.0",
    "open": "^10.1.0",
    "react": "^18.3.1",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.3",
    "@types/yargs": "^17.0.32",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  },
  "keywords": [
    "deepseek",
    "cli",
    "tui",
    "ai",
    "agent",
    "coding",
    "terminal",
    "claude-code-compat"
  ],
  "author": "yinshuo-thu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yinshuo-thu/deepseek-cli.git"
  }
}
